# Copy to .env and fill in your values
# cp .env.example .env
# Get IDs by enabling Developer Mode in Discord (Settings → App Settings → Advanced)
# then right-clicking any server/channel/message → Copy ID

DISCORD_TOKEN=your_bot_token_from_discord_developer_portal

# Your server (guild) ID
GUILD_ID=000000000000000000

# Channel IDs
WELCOME_CHANNEL_ID=000000000000000000
VERIFY_CHANNEL_ID=000000000000000000
UPDATES_CHANNEL_ID=000000000000000000

# The ID of the specific message users react to for verification
VERIFY_MESSAGE_ID=000000000000000000

# The ID of the specific message users react to for game roles
REACTION_ROLES_MESSAGE_ID=000000000000000000

# The ID of the "Create VC" voice channel
VOICE_CREATOR_CHANNEL_ID=000000000000000000

# Role IDs
VERIFIED_ROLE_ID=000000000000000000

# Game role IDs (one per game emoji in bot.py)
GAME1_ROLE_ID=000000000000000000
GAME2_ROLE_ID=000000000000000000
GAME3_ROLE_ID=000000000000000000
GAME4_ROLE_ID=000000000000000000
GAME5_ROLE_ID=000000000000000000
GAME6_ROLE_ID=000000000000000000
GAME7_ROLE_ID=000000000000000000
GAME8_ROLE_ID=000000000000000000
GAME9_ROLE_ID=000000000000000000
