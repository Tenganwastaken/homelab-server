# Copy to .env and fill in values
# cp .env.example .env

# Immich version — pin it!
# Check: https://github.com/immich-app/immich/releases
IMMICH_VERSION=v1.111.0

# Path where photos/videos will be stored on your media drive
UPLOAD_LOCATION=/mnt/media/immich/library

# Path for the PostgreSQL database files
DB_DATA_LOCATION=/mnt/media/immich/postgres

# PostgreSQL credentials
DB_USERNAME=postgres
DB_PASSWORD=changeme_use_a_strong_password
DB_DATABASE_NAME=immich
